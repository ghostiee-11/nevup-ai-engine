# Frontend environment template — copy to .env.local for local dev.
# In production, set these in Vercel's project settings (Environment Variables).

# Live API base URL. Defaults to the deployed Render service if unset.
NEXT_PUBLIC_API_URL=https://nevup-api-zq85.onrender.com

# Demo HS256 secret used for browser-side JWT minting.
# This is the brief's shared demo secret — it is NOT a production credential.
# Real apps would mint tokens on the backend after authentication.
NEXT_PUBLIC_JWT_SECRET=97791d4db2aa5f689c3cc39356ce35762f0a73aa70923039d8ef72a2840a1b02
